# ─────────────────────────────────────────────────────────────────────────────
# TRAVION — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to travion_backend/.env and fill in all required values.
# NEVER commit your actual .env file — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Server ───────────────────────────────────────────────────────────────────

PORT=3000

# Public URL of this backend (used for payment webhooks and invite links)
# In dev: use ngrok or similar, e.g. https://xxxx.ngrok-free.app
BACKEND_URL=https://your-backend-url.example.com

# Base URL used to generate trip invite links sent to members
# In production set to your real domain
APP_BASE_URL=https://yourdomain.com


# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get keys at: https://aistudio.google.com/apikey
# Create up to 4 keys for automatic rotation to avoid rate limits

GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=


# ─── Google Maps ──────────────────────────────────────────────────────────────
# Get key at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API, Distance Matrix API, Directions API, Maps JavaScript API

GOOGLE_MAPS_API_KEY=


# ─── SerpAPI ──────────────────────────────────────────────────────────────────
# Get keys at: https://serpapi.com → Dashboard → API Key
# Create up to 5 keys for rotation (each has its own monthly quota)

SERP_API_KEY=
SERP_API_KEY_2=
SERP_API_KEY_3=
SERP_API_KEY_4=
SERP_API_KEY_5=


# ─── Redis (BullMQ job queues) ────────────────────────────────────────────────
# Install Redis locally: https://redis.io/docs/getting-started/
# Windows: use Memurai (https://www.memurai.com) or WSL2

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
# Get key at: https://openweathermap.org/api → My API Keys
# Free tier includes current weather + 5-day forecasts

OPENWEATHER_API_KEY=


# ─── Amadeus Flights ──────────────────────────────────────────────────────────
# Get credentials at: https://developers.amadeus.com → My Apps → Create App
# Use test URL for development; switch to prod when going live

AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com


# ─── AviationStack (Flight status & delays) ───────────────────────────────────
# Get key at: https://aviationstack.com → Dashboard → API Access Key
# Free tier: 100 requests/month

AVIATION_STACK_API_KEY=


# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these at: https://supabase.com → Your Project → Settings → API
# WARNING: SUPABASE_SERVICE_KEY bypasses Row Level Security.
#          Keep it backend-only. Never expose in frontend code.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=


# ─── Dodo Payments ────────────────────────────────────────────────────────────
# Sign up at: https://dodopayments.com → Developers → API Keys
# Set DODO_ENVIRONMENT to test_mode for development, live_mode for production

DODO_API_KEY=
DODO_API_SECRET=
DODO_PUBLISHABLE_KEY=
DODO_ENVIRONMENT=test_mode

# Create two Products in Dodo dashboard and paste their IDs here
DODO_PRODUCT_ID_PRO_MONTHLY=
DODO_PRODUCT_ID_PRO_ANNUAL=


# ─── OpenRouter (Mistral-7B — chatbot + NLP) ──────────────────────────────────
# Get key at: https://openrouter.ai → Profile → Keys → Create Key
# Model used: mistralai/mistral-7b-instruct (free credits on signup)

OPENROUTER_API_KEY=
